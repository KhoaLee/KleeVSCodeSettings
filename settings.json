{
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "screencastMode.fontSize": 60,
  "window.commandCenter": true,
  "breadcrumbs.enabled": false,
  "editor.codeLens": false,
  "search.searchOnType": false,
  "telemetry.telemetryLevel": "off",
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/env": true,
    "**/venv": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/env/**": true,
    "**/venv/**": true,
    "env-*": true
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.vscode": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "venv": true,
    "*.sublime-*": true,
    "env*": true,
    "**/.git/objects/**": true,
    "**/node_modules": true
  },
  // =============================== EDITOR SETTIGNS ===============================
  "editor.codeLensFontFamily": "Hasklug Nerd Font Mono",
  "editor.inlayHints.fontFamily": "Hasklug Nerd Font Mono",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.foldingImportsByDefault": true,
  "editor.letterSpacing": 0.5,
  "editor.tabCompletion": "on",
  "editor.foldingMaximumRegions": 10000,
  "editor.tabSize": 4,
  "editor.guides.bracketPairs": true,
  "editor.suggestSelection": "first",
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on",
    "other": "on"
  },
  "editor.codeActionsOnSave": {
    "source.organizeImports": true
  },
  "editor.formatOnSave": true,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "block",
  "editor.linkedEditing": true,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.fontFamily": "Hasklug Nerd Font Mono, 'Hasklug Nerd Font Mono', Hasklug Nerd Font Mono",
  // =============================== JSON FORMAT SETTINGS ===============================
  "json.maxItemsComputed": 10000,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ======================================= SETTING FOR DEBUGGING ======================================
  "debug.terminal.clearBeforeReusing": true,
  "debug.autoExpandLazyVariables": true,
  "debug.console.fontFamily": "Hasklug Nerd Font Mono, 'Hasklug Nerd Font Mono', Hasklug Nerd Font Mono",
  // ======================================= SETTING FOR INTEGRATED TERMINAL =======================================
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "/bin/zsh",
      "args": ["-l"]
    }
  },
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.letterSpacing": 1.15,
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.shellIntegration.decorationsEnabled": "both",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
  "terminal.integrated.detectLocale": "on",
  "terminal.external.osxExec": "warp.app",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.allowChords": false,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.customGlyphs": true,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.fontFamily": "Hasklug Nerd Font Mono, 'Hasklug Nerd Font Mono', Hasklug Nerd Font Mono",
  "terminal.integrated.cursorWidth": 3,
  "terminal.integrated.tabs.defaultIcon": "terminal-bash",
  // ======================================= FILES SETTINGS =======================================
  "files.autoSave": "afterDelay",
  "files.trimTrailingWhitespace": true,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.preferredHighContrastColorTheme": "Base16 Tomorrow",
  "workbench.preferredDarkColorTheme": "Base16 Tomorrow",
  "workbench.editor.enablePreview": false,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  // https://glitchbone.github.io/vscode-base16-term/#/tomorrow-night
  "workbench.colorCustomizations": {
    "terminal.background": "#1D1F21",
    "terminal.foreground": "#C5C8C6",
    "terminalCursor.background": "#C5C8C6",
    "terminalCursor.foreground": "#C5C8C6",
    "terminal.ansiBlack": "#1D1F21",
    "terminal.ansiBlue": "#81A2BE",
    "terminal.ansiBrightBlack": "#969896",
    "terminal.ansiBrightBlue": "#81A2BE",
    "terminal.ansiBrightCyan": "#8ABEB7",
    "terminal.ansiBrightGreen": "#B5BD68",
    "terminal.ansiBrightMagenta": "#B294BB",
    "terminal.ansiBrightRed": "#CC6666",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminal.ansiBrightYellow": "#F0C674",
    "terminal.ansiCyan": "#8ABEB7",
    "terminal.ansiGreen": "#B5BD68",
    "terminal.ansiMagenta": "#B294BB",
    "terminal.ansiRed": "#CC6666",
    "terminal.ansiWhite": "#C5C8C6",
    "terminal.ansiYellow": "#F0C674"
  },
  // ======================================= EXPLORER SETTINGS =======================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  // ======================================= LANGUAGES SETTINGS =======================================
  // ======================================= JAVA CONFIGURATION =======================================
  "[java]": {
    "editor.formatOnSave": true,
    "editor.suggest.snippetsPreventQuickSuggestions": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },
  "java.jdt.ls.java.home": "/Library/Java/JavaVirtualMachines/jdk-17.0.3.1.jdk/Contents/Home",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-1.8",
      "path": "/Library/Java/JavaVirtualMachines/jdk1.8.0_333.jdk/Contents/Home"
    },
    {
      "name": "JavaSE-11",
      "path": "/Library/Java/JavaVirtualMachines/jdk-11.0.15.jdk/Contents/Home",
      "default": true
    },
    {
      "name": "JavaSE-17",
      "path": "/Library/Java/JavaVirtualMachines/jdk-17.0.3.1.jdk/Contents/Home"
    }
  ],
  "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx1G -Xms100m -javaagent:\"/Users/klee/.vscode/extensions/gabrielbb.vscode-lombok-1.0.1/server/lombok.jar\"",
  "maven.terminal.useJavaHome": true,
  "java.format.settings.url": "https://raw.githubusercontent.com/google/styleguide/gh-pages/eclipse-java-google-style.xml",
  "java.format.settings.profile": "GoogleStyle",
  // ======================================= HTML,JAVASCRIPT,TYPESCRIPT CONFIGURATION =======================================
  "html.autoClosingTags": true,
  "javascript.autoClosingTags": true,
  "typescript.autoClosingTags": true,
  // ======================================= XML CONFIGURATION =======================================
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  // ======================================= PYTHON CONFIGURATION =======================================
  "python.linting.flake8Enabled": true,
  "python.formatting.autopep8Args": [
    "--max-line-length=200",
    "--ignore=E502,F841,E402,W503"
  ],
  "python.linting.flake8Args": ["--ignore=E501,F841,E402,W503"],
  "python.defaultInterpreterPath": "~/.pyenv/versions/ytubescraper-env",
  "python.languageServer": "Pylance",
  "python.analysis.autoImportCompletions": true,
  "[python]": {
    "editor.wordBasedSuggestions": false
  },
  // ########### JAVASCRIPT CONFIGURATION ###########
  "javascript.updateImportsOnFileMove.enabled": "always",
  "jshint.options": {
    "esversion": 9
  },
  // ======================================= EXTENSIONS SETTINGS =======================================
  // ======================================= PRETTIER CONFIGURATION =======================================
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.formatOnSave": true
  },
  "[javascript][javascriptreact][typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },
  "[json][jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[css][scss][less]": {
    "editor.defaultFormatter": "vscode.css-language-features",
    "editor.formatOnSave": true
  },

  // ########### GIT CONFIGURATION ###########
  "git.confirmSync": false,
  "git.autorefresh": false,
  // ########### AWS CONFIGURATION ###########
  "aws.profile": "profile:default",
  "aws.telemetry": false,
  // ########### NOTEBOOK CONFIGURATION ###########
  "jupyter.askForKernelRestart": false,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "right"
  },
  "notebook.breadcrumbs.showCodeCells": false,
  "jupyter.alwaysTrustNotebooks": true,
  // ########### LIVESERVER CONFIGURATION ###########
  "liveServer.settings.donotShowInfoMsg": true,
  // ########### REDHAT CONFIGURATION ###########
  "redhat.telemetry.enabled": false,
  // ########### KUBERNETES CONFIGURATION ###########
  "vs-kubernetes": {
    "vscode-kubernetes.helm-path.mac": "/Users/klee/.vs-kubernetes/tools/helm/darwin-amd64/helm",
    "vscode-kubernetes.minikube-path.mac": "/Users/klee/.vs-kubernetes/tools/minikube/darwin-amd64/minikube"
  },
  // ########### SYNCSETTINGS CONFIGURATION ###########
  "sync.gist": "2ef1e47be50cf21e58518e6c732a7dad",
  "sync.autoDownload": false,
  "sync.autoUpload": false,
  "sync.forceDownload": false,
  "sync.forceUpload": false,
  "sync.quietSync": false,
  "sync.removeExtensions": true,
  "sync.syncExtensions": true,
  //============================================= VIM CONFIGURATION =============================================
  "vim.cursorStylePerMode.insert": "underline",
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.replace": "line",
  "vim.cursorStylePerMode.visual": "line",
  "vim.cursorStylePerMode.visualblock": "line",
  "vim.cursorStylePerMode.visualline": "line",
  "vim.easymotion": true,
  "vim.surround": true,
  "vim.scroll": 5,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.sneak": true,
  "vim.autoindent": true,
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"]
    }
  ],
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    },
    {
      "before": ["<C-j>"],
      "after": ["<Esc>"]
    },
    {
      "before": ["<C-k>"],
      "after": ["<Esc>"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [">"],
      "after": [">", "g", "v"]
    },
    {
      "before": ["<"],
      "after": ["<", "g", "v"]
    },
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"]
    },
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "before": ["<leader>", "f"],
      "commands": ["revealInExplorer"]
    },
    {
      "before": ["<leader>", "h"],
      "after": ["_"]
    },
    {
      "before": ["<leader>", "l"],
      "after": ["$"]
    }
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    // VS Code new marker @ next occurence
    "<C-c>": true,
    // Cut
    "<C-x>": false,
    // Paste
    "<C-v>": true,
    "<C-z>": false
    // "<C-y>": false
  },
  "yaml.customTags": [
    "!And",
    "!And sequence",
    "!If",
    "!If sequence",
    "!Not",
    "!Not sequence",
    "!Equals",
    "!Equals sequence",
    "!Or",
    "!Or sequence",
    "!FindInMap",
    "!FindInMap sequence",
    "!Base64",
    "!Join",
    "!Join sequence",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!Sub sequence",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!ImportValue sequence",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Split sequence"
  ],
  "git.terminalGitEditor": true,
  "aws.samcli.location": "/usr/local/bin/sam",
  "sonarlint.rules": {
    "java:S125": {
      "level": "off"
    },
    "typescript:S125": {
      "level": "off"
    },
    "python:S125": {
      "level": "off"
    },
    "python:S112": {
      "level": "off"
    }
  },
  "git.enableSmartCommit": true,
  "editor.wordWrapColumn": 160,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "xml.format.maxLineWidth": 160,
  "yaml.format.printWidth": 160,
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  "python.analysis.typeCheckingMode": "basic",
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "git-graph.dialog.rebase.launchInteractiveRebase": true,
  "css.enabledLanguages": ["html"],
  "scm.inputFontSize": 12,
  "markdown.preview.fontSize": 12,
  "workbench.tree.indent": 12,
  "javascript.format.semicolons": "insert",
  "typescript.format.semicolons": "insert",
  "editor.lineHeight": 1.75,
  "diffEditor.wordWrap": "on",
  "editor.fontWeight": "normal",
  "notebook.outputFontFamily": "Jetbrains Nerd Font Mono, 'Jetbrains Nerd Font Mono', Jetbrains Nerd Font Mono",
  "mssql.resultsFontSize": 12,
  "workbench.iconTheme": "vscode-icons",
  "workbench.colorTheme": "Base16 Tomorrow",
  "python.formatting.provider": "black"
}
